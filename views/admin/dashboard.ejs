<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - AveragezXD</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-title">🎬 Admin</div>
      </div>
      <nav class="sidebar-nav">
        <button class="nav-item active" data-tab="projects">📁 Projects</button>
        <button class="nav-item" data-tab="settings">⚙️ Settings</button>
        <a href="/admin/logout" class="nav-item">🚪 Logout</a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <div class="admin-header">
        <div class="header-title">
          <h1>Dashboard</h1>
          <p>Manage your portfolio with ease</p>
        </div>
        <div class="header-actions">
          <button class="btn btn-primary" data-action="add-project">+ Add Project</button>
          <button class="theme-toggle">☀️</button>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total Projects</div>
          <div class="stat-value" data-stat="total-projects">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Views</div>
          <div class="stat-value" data-stat="total-views">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Categories</div>
          <div class="stat-value" data-stat="categories">0</div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs">
        <button class="tab-btn active" data-tab="projects">Projects</button>
        <button class="tab-btn" data-tab="settings">Settings</button>
      </div>

      <!-- Projects Tab -->
      <div id="projects-tab" class="tab-content active">
        <div class="table-container">
          <table id="projectsTable">
            <thead>
              <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Views</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Settings Tab -->
      <div id="settings-tab" class="tab-content">
        <div style="max-width: 600px;">
          <h3>Portfolio Settings</h3>
          <form id="settingsForm" style="margin-top: 2rem;">
            <div class="form-group">
              <label for="discordUsername">Discord Username</label>
              <input type="text" id="discordUsername" name="discordUsername" required>
            </div>
            <div class="form-group">
              <label for="newPassword">Change Admin Password (Leave blank to keep current)</label>
              <input type="password" id="newPassword" name="newPassword">
            </div>
            <button type="submit" class="btn btn-primary">Save Settings</button>
          </form>
        </div>
      </div>
    </main>
  </div>

  <!-- Project Modal -->
  <div id="projectModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Add New Project</h2>
        <button class="modal-close">✕</button>
      </div>
      <form id="projectForm" enctype="multipart/form-data" data-mode="create">
        <div class="form-group">
          <label for="title">Project Title</label>
          <input type="text" id="title" name="title" required>
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" required></textarea>
        </div>
        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category" required>
            <option value="cutscene">Cutscene</option>
            <option value="combat">Combat</option>
            <option value="emotes">Emotes</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label for="link">Project Link</label>
          <input type="url" id="link" name="link" required>
        </div>
        <div class="form-group">
          <label for="thumbnail">Thumbnail Image</label>
          <input type="file" id="thumbnail" name="thumbnail" accept="image/*">
        </div>
        <div style="display: flex; gap: 1rem;">
          <button type="submit" class="btn btn-primary">Save Project</button>
          <button type="button" class="btn btn-secondary" onclick="document.getElementById('projectModal').classList.remove('active')">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/admin.js"></script>
</body>
</html>
